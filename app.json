{
  "expo": {
    "name": "FitControl",
    "slug": "FitControl",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/LogoIcon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "fitcontrol",
    "splash": {
      "image": "./assets/LogoIcon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF",
      "dark": {
        "image": "./assets/LogoIcon2.png",
        "backgroundColor": "#23252E" 
      }
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.wilfermarquez11.FitControl",
      "backgroundColor": "#FFFFFF",

      "adaptiveIcon": {
        "foregroundImage": "./assets/LogoIcon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-status-bar",
      "expo-font",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "b28ff6ab-5e19-4457-9102-118b4f70d9c1"
      }
    }
  }
}